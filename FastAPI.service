[Unit]
Description=FastAPI Application
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/mi-fastapi-aws
ExecStart=/home/ubuntu/mi-fastapi-aws/venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000

Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
